# ============================================
# Configuração para Arquitetura Híbrida
# Oracle E2.1.Micro + Vercel + Neon
# ============================================
# Copie este arquivo para .env.micro e configure

# ============================================
# NEON POSTGRESQL (https://neon.tech)
# ============================================
# 1. Crie conta gratuita em https://neon.tech
# 2. Crie um projeto
# 3. Copie a connection string
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/pub_system?sslmode=require

# ============================================
# JWT SECRET
# ============================================
# Gere com: openssl rand -base64 32
JWT_SECRET=sua-chave-secreta-aqui-minimo-32-caracteres

# ============================================
# URLs
# ============================================
# Backend: IP público da Oracle ou domínio
BACKEND_URL=https://api.seudominio.com
# Frontend: URL do Vercel
FRONTEND_URL=https://seu-app.vercel.app

# ============================================
# ADMIN INICIAL (primeiro deploy)
# ============================================
ADMIN_EMAIL=admin@seudominio.com
ADMIN_SENHA=SenhaForte123!

# ============================================
# GOOGLE CLOUD STORAGE (opcional)
# ============================================
# Se não usar, deixe vazio - imagens serão salvas localmente
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================
# CORS (domínios permitidos)
# ============================================
CORS_ORIGINS=https://seu-app.vercel.app,https://seudominio.com
