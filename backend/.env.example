# ============================================
# BACKEND - Variáveis de Ambiente (Exemplo)
# ============================================
# ⚠️  IMPORTANTE: Copie este arquivo para .env e ALTERE TODOS os valores!
# ⚠️  NUNCA commite o arquivo .env no repositório!

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=development

# ============================================
# REDIS (OBRIGATÓRIO para cache e rate limiting)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# BANCO DE DADOS (OBRIGATÓRIO)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=ALTERE_PARA_SENHA_FORTE
DB_DATABASE=pub_system_db

# ============================================
# SEGURANÇA (OBRIGATÓRIO)
# ============================================
# ⚠️  JWT_SECRET deve ter no MÍNIMO 32 caracteres!
# Gere uma chave segura com: openssl rand -base64 32
JWT_SECRET=GERE_UMA_CHAVE_COM_MINIMO_32_CARACTERES_AQUI

# Refresh Token - Rotação automática (true = mais seguro)
ROTATE_REFRESH_TOKEN=true

# ============================================
# CORS - URL do Frontend (OBRIGATÓRIO)
# ============================================
# Em produção, use o domínio real: https://app.seudominio.com
FRONTEND_URL=http://localhost:3001

# ============================================
# SETUP ENDPOINT (OPCIONAL — desabilitado por padrão)
# ============================================
# ⚠️  Só habilite para criar o primeiro Super Admin, depois desabilite!
# ENABLE_SETUP=true
# SETUP_TOKEN=GERE_UM_TOKEN_ALEATORIO_AQUI

# ============================================
# GOOGLE CLOUD STORAGE (OPCIONAL)
# ============================================
GCS_BUCKET_NAME=pub-system-media-storage
GOOGLE_APPLICATION_CREDENTIALS=./gcs-credentials.json

# ============================================
# ADMINISTRADOR INICIAL (OPCIONAL)
# ============================================
# ⚠️  Use apenas no primeiro deploy, depois remova!
# ⚠️  ADMIN_SENHA deve ter no mínimo 8 caracteres!
# ADMIN_EMAIL=admin@seudominio.com
# ADMIN_SENHA=SENHA_FORTE_MINIMO_8_CHARS

# ============================================
# LOGS E ALERTAS (OPCIONAL)
# ============================================
# LOG_DIR=logs
# LOG_LEVEL=info
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ============================================
# BACKUP (OPCIONAL)
# ============================================
# BACKUP_DIR=./backups
# BACKUP_MAX_AGE_HOURS=24
