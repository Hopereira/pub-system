# ============================================
# CONFIGURAÇÃO DO BANCO DE DADOS (PostgreSQL)
# ============================================

# Host do banco (use 'db' para Docker, 'localhost' para desenvolvimento local)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_DATABASE=pub_system_db

# Variáveis que o container do Postgres usa na inicialização
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=pub_system_db

# ============================================
# PGADMIN (Ferramenta de Gerenciamento do BD)
# ============================================
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# ============================================
# SEGURANÇA (JWT)
# ============================================
# IMPORTANTE: Troque este segredo em produção!
# Use um valor longo e aleatório (ex: openssl rand -base64 32)
JWT_SECRET=substitua-por-um-segredo-forte-e-aleatorio-em-producao

# ============================================
# CREDENCIAIS DO ADMINISTRADOR INICIAL
# ============================================
ADMIN_EMAIL=admin@admin.com
ADMIN_SENHA=admin123

# ============================================
# GOOGLE CLOUD STORAGE (Upload de Imagens)
# ============================================
# Nome do bucket no GCS
GCS_BUCKET_NAME=pub-system-media-storage

# Caminho para o arquivo de credenciais JSON do GCS
# Docker: /usr/src/app/gcs-credentials.json
# Local: ./backend/gcs-credentials.json
GOOGLE_APPLICATION_CREDENTIALS=/usr/src/app/gcs-credentials.json

# ============================================
# URLS (Frontend e Backend)
# ============================================
BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL_SERVER=http://backend:3000
